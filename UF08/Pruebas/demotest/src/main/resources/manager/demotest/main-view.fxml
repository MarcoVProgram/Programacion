<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.effect.Lighting?>
<?import javafx.scene.effect.Shadow?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" maxHeight="640.0" maxWidth="640.0" minHeight="640.0" minWidth="640.0" prefHeight="640.0" prefWidth="640.0" spacing="20.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="manager.demotest.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <Button fx:id="helloButton" onAction="#onHelloButtonClick" prefHeight="13.0" prefWidth="90.0" styleClass="helloButton" stylesheets="@style.css" text="¡Hola!" textAlignment="CENTER" textFill="WHITE" VBox.vgrow="ALWAYS">
      <font>
         <Font size="18.0" />
      </font>
      <cursor>
         <Cursor fx:constant="HAND" />
      </cursor>
      <effect>
         <DropShadow />
      </effect>
   </Button>

    <Label fx:id="hiddenText">
      <font>
         <Font name="SansSerif Regular" size="14.0" />
      </font></Label>
   <GridPane prefHeight="176.0" prefWidth="600.0">
     <columnConstraints>
       <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
       <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
     </columnConstraints>
     <rowConstraints>
       <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
       <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
       <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
         <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
     </rowConstraints>
      <children>
         <Button maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" nodeOrientation="RIGHT_TO_LEFT" onAction="#onSelectButtonClick" styleClass="menu-button" stylesheets="@style.css" text="Select" GridPane.halignment="LEFT" GridPane.valignment="CENTER" GridPane.vgrow="ALWAYS">
            <cursor>
               <Cursor fx:constant="HAND" />
            </cursor>
            <padding>
               <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
            </padding>
            <GridPane.margin>
               <Insets bottom="10.0" />
            </GridPane.margin>
         </Button>
         <Button maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" onAction="#onDeleteButtonClick" styleClass="menu-button" stylesheets="@style.css" text="Delete" textAlignment="JUSTIFY" GridPane.halignment="LEFT" GridPane.rowIndex="2" GridPane.valignment="CENTER" GridPane.vgrow="ALWAYS">
            <cursor>
               <Cursor fx:constant="HAND" />
            </cursor>
            <padding>
               <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
            </padding>
            <GridPane.margin>
               <Insets bottom="10.0" />
            </GridPane.margin>
         </Button>
         <Button maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" onAction="#onAddButtonClick" styleClass="menu-button" stylesheets="@style.css" text="Add" GridPane.halignment="LEFT" GridPane.rowIndex="1" GridPane.valignment="CENTER" GridPane.vgrow="ALWAYS">
            <cursor>
               <Cursor fx:constant="HAND" />
            </cursor>
            <padding>
               <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
            </padding>
            <GridPane.margin>
               <Insets bottom="10.0" />
            </GridPane.margin>
         </Button>
         <Label fx:id="hiddenText1" alignment="CENTER" lineSpacing="1.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" wrapText="true" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.hgrow="ALWAYS" GridPane.vgrow="ALWAYS">
            <effect>
               <InnerShadow />
            </effect>
            <font>
               <Font name="Segoe UI" size="12.0" />
            </font>
         </Label>
         <Label fx:id="hiddenText3" alignment="CENTER" lineSpacing="1.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" wrapText="true" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.hgrow="ALWAYS" GridPane.rowIndex="2" GridPane.vgrow="ALWAYS">
            <effect>
               <InnerShadow />
            </effect>
            <font>
               <Font name="Segoe UI" size="12.0" />
            </font>
         </Label>
         <Label fx:id="hiddenText2" alignment="CENTER" lineSpacing="1.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" wrapText="true" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.hgrow="ALWAYS" GridPane.rowIndex="1" GridPane.vgrow="ALWAYS">
            <effect>
               <InnerShadow />
            </effect>
            <font>
               <Font name="Segoe UI" size="12.0" />
            </font>
         </Label>
         <Label fx:id="hiddenText4" alignment="CENTER" lineSpacing="1.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" wrapText="true" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.hgrow="ALWAYS" GridPane.rowIndex="3" GridPane.vgrow="ALWAYS">
            <effect>
               <InnerShadow />
            </effect>
            <font>
               <Font name="Segoe UI" size="12.0" />
            </font>
         </Label>
         <CheckBox mnemonicParsing="false" onAction="#onToggleButtonToggle" text="¿Eres Sabio?" GridPane.rowIndex="3" />
      </children>
      <cursor>
         <Cursor fx:constant="HAND" />
      </cursor>
      <effect>
         <Lighting>
            <bumpInput>
               <Shadow />
            </bumpInput>
            <light>
            </light>
         </Lighting>
      </effect>
   </GridPane>
   <ButtonBar prefHeight="40.0" prefWidth="128.0">
      <buttons>
       <Button alignment="CENTER" cancelButton="true" mnemonicParsing="false" onAction="#onExitButtonClick" styleClass="cancel-button" text="Salir" textOverrun="CENTER_WORD_ELLIPSIS" />
      </buttons>
   </ButtonBar>
</VBox>
